#!/usr/bin/env ruby
# frozen_string_literal: true

require "csv"
require "set"
require "fileutils"

csv_path = "events.csv"
images_dir = "events_listing/assets/images"

unless File.exist?(csv_path)
  puts "CSV file not found"
  exit 1
end

referenced = CSV.foreach(csv_path, headers: true).map { |r| r["image"] }.compact.map(&:strip).to_set
existing = Dir.glob(File.join(images_dir, "*.webp")).map { |f| File.basename(f, ".webp") }.to_set

unreferenced = existing - referenced

unreferenced.each do |uuid|
  file = File.join(images_dir, "#{uuid}.webp")
  if system("git rm -f \"#{file}\"")
    puts "Removed via git: #{file}"
  else
    FileUtils.rm_f(file)
    puts "Removed via FileUtils: #{file}"
  end
end
